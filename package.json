{
  "name": "architect-companion",
  "version": "0.0.0",
  "description": "An opinionated architecture harness for agentic engineering.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "architect-companion": "./dist/cli.js"
  },
  "files": [
    "dist",
    "profiles",
    "assets",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect:dependency-cruiser": "npm run build && node scripts/inspect-dependency-cruiser-config.mjs",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "update:goldens": "vitest run -u"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "yaml": "^2.9.0"
  }
}
